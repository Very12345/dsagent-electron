{
  "name": "dsagent-electron",
  "version": "5.0.1",
  "description": "DeepSeek Local Agent - Electron desktop app",
  "main": "main.js",
  "bin": {
    "dsagent": "./bin/dsagent.js"
  },
  "scripts": {
    "start": "chcp 65001 > nul & electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --x64",
    "dist:portable": "electron-builder --win --x64 --config.portable=true",
    "pack": "electron-packager . dsagent-electron --all",
    "pack:win": "electron-packager . dsagent-electron --platform=win32 --arch=x64 --out=dist_pack",
    "pack:update": "echo 打包更新文件（不含Electron）供已有安装的人覆盖更新 && powershell Compress-Archive -Path main.js,preload-*.js,agentview.html,controlbar.html,filebrowser.html,inject.js,qwen_inject.js,tools,utils -DestinationPath update.zip -Force",
    "prepublishOnly": "node -e \"var fs=require('fs'); ['build'].forEach(d=>{if(!fs.existsSync(d))fs.mkdirSync(d)});\""
  },
  "files": [
    "bin/",
    "tools/",
    "main.js",
    "inject.js",
    "qwen_inject.js",
    "preload-agent.js",
    "preload.js",
    "agentview.html",
    "controlbar.html",
    "filebrowser.html",
    "viewbar.html",
    "config.json",
    "history-manager.js",
    "qqbot.js",
    "server.js",
    "build/"
  ],
  "dependencies": {
    "axios": "^1.17.0",
    "electron-updater": "^6.8.9",
    "iconv-lite": "^0.6.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.deepseek.dsagent",
    "productName": "DeepSeek Agent",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "Very12345",
      "repo": "dsagent-electron"
    },
    "files": [
      "**/*",
      "!node_modules/.bin",
      "!*.map"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
